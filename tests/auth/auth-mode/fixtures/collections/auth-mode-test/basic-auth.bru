meta {
  name: basic-auth
  type: http
  seq: 2
}

get {
  url: http://localhost:8081/ping
  body: none
  auth: basic
}

auth:basic {
  username: user
  password: password
}

script:pre-request {
  test("detects Basic auth in pre-request script", function() {
    expect(req.getAuthMode()).to.equal("basic");
  });
}

tests {
  test("detects Basic auth after interpolation", function() {
    expect(req.getAuthMode()).to.equal("basic");
  });
}
