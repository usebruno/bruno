meta {
  name: inherited-basic-auth
  type: http
  seq: 1
}

get {
  url: http://localhost:8081/ping
  body: none
  auth: inherit
}

script:pre-request {
  test("detects inherited Basic auth in pre-request script", function() {
    expect(req.getAuthMode()).to.equal("basic");
  });
}

tests {
  test("detects inherited Basic auth in test script", function() {
    expect(req.getAuthMode()).to.equal("basic");
  });
}
