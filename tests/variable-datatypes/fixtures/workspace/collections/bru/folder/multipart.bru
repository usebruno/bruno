meta {
  name: multipart
  type: http
  seq: 2
}

post {
  url: {{localhost}}/api/echo/everything
  body: multipartForm
  auth: none
}

body:multipart-form {
  mp_str: {{mp_str}}
  mp_num: {{mp_num}}
  mp_bool: {{mp_bool}}
  mp_obj: {{mp_obj}}
}

vars:pre-request {
  mp_str: form_string
  @number
  mp_num: 42
  @boolean
  mp_bool: true
  @object
  mp_obj: '''
    {"key":"value"}
  '''
}

tests {
  test("multipart text fields stringify typed values on the wire", () => {
    const raw = res.getBody().body;
    const fieldValue = (name) => {
      const match = raw.match(new RegExp(`name="${name}"\\r?\\n\\r?\\n([\\s\\S]*?)\\r?\\n--`));
      return match && match[1];
    };
    expect(fieldValue("mp_str")).to.equal("form_string");
    expect(fieldValue("mp_num")).to.equal("42");
    expect(fieldValue("mp_bool")).to.equal("true");
    expect(fieldValue("mp_obj")).to.equal('{"key":"value"}');
  });
}
