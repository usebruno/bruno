meta {
  name: request
  type: http
  seq: 1
}

post {
  url: {{localhost}}/api/echo/everything?q=hi&p_str={{req_str}}&p_num={{req_num}}&p_bool={{req_bool}}&p_obj={{req_obj}}
  body: json
  auth: none
}

params:query {
  q: hi
  p_str: {{req_str}}
  p_num: {{req_num}}
  p_bool: {{req_bool}}
  p_obj: {{req_obj}}
}

headers {
  x-test: hello
  x-h-str: {{req_str}}
  x-h-num: {{req_num}}
  x-h-bool: {{req_bool}}
  x-h-obj: {{req_obj}}
}

body:json {
  {
    "coll_str": "{{coll_str}}",
    "coll_num": {{coll_num}},
    "coll_bool": {{coll_bool}},
    "coll_obj": {{coll_obj}},
    "fold_str": "{{fold_str}}",
    "fold_num": {{fold_num}},
    "fold_bool": {{fold_bool}},
    "fold_obj": {{fold_obj}},
    "req_str": "{{req_str}}",
    "req_num": {{req_num}},
    "req_bool": {{req_bool}},
    "req_obj": {{req_obj}},
    "req_obj_precision": {{req_obj_precision}},
    "req_obj_empty": {{req_obj_empty}},
    "req_arr": {{req_arr}},
    "mismatched_num": "{{mismatched_num}}",
    "env_str": "{{env_str}}",
    "env_num": {{env_num}},
    "env_bool": {{env_bool}},
    "env_obj": {{env_obj}},
    "falsy_num": {{falsy_num}},
    "falsy_bool": {{falsy_bool}},
    "glob_str": "{{glob_str}}",
    "glob_num": {{glob_num}},
    "glob_bool": {{glob_bool}},
    "glob_obj": {{glob_obj}},
    "runtime_str": "{{runtime_str}}",
    "runtime_num": {{runtime_num}},
    "runtime_bool": {{runtime_bool}},
    "runtime_obj": {{runtime_obj}},
    "inferred_env_num": {{inferred_env_num}},
    "inferred_env_bool": {{inferred_env_bool}},
    "inferred_env_obj": {{inferred_env_obj}},
    "inferred_glob_num": {{inferred_glob_num}},
    "inferred_glob_bool": {{inferred_glob_bool}},
    "inferred_glob_obj": {{inferred_glob_obj}},
    "env_secret_str": "{{env_secret_str}}",
    "glob_secret_str": "{{glob_secret_str}}",
    "env_secret_num": {{env_secret_num}},
    "glob_secret_num": {{glob_secret_num}},
    "env_secret_bool": {{env_secret_bool}},
    "glob_secret_bool": {{glob_secret_bool}},
    "env_secret_obj": {{env_secret_obj}},
    "glob_secret_obj": {{glob_secret_obj}}
  }
}

vars:pre-request {
  req_str: request_string
  @number
  req_num: 42
  @boolean
  req_bool: true
  @object
  req_obj: '''
    {"key":"value"}
  '''
  @object
  req_obj_precision: '''
    {"integer":123,"negativeInteger":-99,"zero":0,"float":2.718,"negativeFloat":-1.618,"largeDouble":12345.678901234567,"smallDouble":9.876e-12,"booleanTrue":true,"booleanFalse":false}
  '''
  @object
  req_obj_empty: '''
    {}
  '''
  @number
  mismatched_num: not-a-number
  @object
  req_arr: '''
    [1, 2, "three", true]
  '''
}

script:pre-request {
  // Seed runtime variables so tests can exercise bru.getVar() with each dataType.
  bru.setVar("runtime_str", "runtime_string");
  bru.setVar("runtime_num", 999);
  bru.setVar("runtime_bool", true);
  bru.setVar("runtime_obj", { nested: "yes" });

  // Seed env / global env vars so tests can verify that bru.setEnvVar / bru.setGlobalEnvVar
  // infer the dataType and surface it in the env editor.
  bru.setEnvVar("inferred_env_num", 700);
  bru.setEnvVar("inferred_env_bool", true);
  bru.setEnvVar("inferred_env_obj", { from: "script" });
  bru.setGlobalEnvVar("inferred_glob_num", 800);
  bru.setGlobalEnvVar("inferred_glob_bool", false);
  bru.setGlobalEnvVar("inferred_glob_obj", { from: "script" });

  // Seed secret env vars. A secret's value is never written to disk; its
  // dataType is. setEnvVar keeps the value's JS type at runtime (the electron
  // store stringifies it before encryption only when persisting).
  bru.setEnvVar("env_secret_str", "secret_env_string");
  bru.setGlobalEnvVar("glob_secret_str", "secret_global_string");
  bru.setEnvVar("env_secret_num", 50);
  bru.setGlobalEnvVar("glob_secret_num", 60);
  bru.setEnvVar("env_secret_bool", true);
  bru.setGlobalEnvVar("glob_secret_bool", false);
  bru.setEnvVar("env_secret_obj", { scope: "env_secret" });
  bru.setGlobalEnvVar("glob_secret_obj", { scope: "global_secret" });

  // bru.set* identifies type from the value's runtime type, not string
  // content. Numeric / boolean / JSON-looking strings stay strings.
  bru.setEnvVar("strict_num_str", "42");
  bru.setEnvVar("strict_bool_str", "true");
  bru.setEnvVar("strict_obj_str", JSON.stringify({ k: 1 }));
  bru.setGlobalEnvVar("strict_glob_num_str", "42");
  bru.setVar("strict_runtime_num_str", "42");
}

tests {
  test("collection vars carry their declared types", () => {
    expect(typeof bru.getCollectionVar("coll_str")).to.equal("string");
    expect(typeof bru.getCollectionVar("coll_num")).to.equal("number");
    expect(bru.getCollectionVar("coll_num")).to.equal(100);
    expect(typeof bru.getCollectionVar("coll_bool")).to.equal("boolean");
    expect(bru.getCollectionVar("coll_bool")).to.equal(false);
    expect(bru.getCollectionVar("coll_obj")).to.deep.equal({ scope: "collection" });
  });

  test("folder vars carry their declared types", () => {
    expect(typeof bru.getFolderVar("fold_str")).to.equal("string");
    expect(typeof bru.getFolderVar("fold_num")).to.equal("number");
    expect(bru.getFolderVar("fold_num")).to.equal(200);
    expect(typeof bru.getFolderVar("fold_bool")).to.equal("boolean");
    expect(bru.getFolderVar("fold_bool")).to.equal(true);
    expect(bru.getFolderVar("fold_obj")).to.deep.equal({ scope: "folder" });
  });

  test("request vars carry their declared types", () => {
    expect(typeof bru.getRequestVar("req_str")).to.equal("string");
    expect(typeof bru.getRequestVar("req_num")).to.equal("number");
    expect(bru.getRequestVar("req_num")).to.equal(42);
    expect(typeof bru.getRequestVar("req_bool")).to.equal("boolean");
    expect(bru.getRequestVar("req_bool")).to.equal(true);
    expect(bru.getRequestVar("req_obj")).to.deep.equal({ key: "value" });

    // {} must stay an object, not fall back to the raw string.
    expect(typeof bru.getRequestVar("req_obj_empty")).to.equal("object");
    expect(bru.getRequestVar("req_obj_empty")).to.deep.equal({});

    expect(Array.isArray(bru.getRequestVar("req_arr"))).to.equal(true);
    expect(bru.getRequestVar("req_arr")).to.deep.equal([1, 2, "three", true]);

    // Uncoerceable @number falls back to the raw string — same signal that drives the mismatch warning icon.
    expect(typeof bru.getRequestVar("mismatched_num")).to.equal("string");
    expect(bru.getRequestVar("mismatched_num")).to.equal("not-a-number");
  });

  test("typed object var preserves number precision through file → parse round-trip", () => {
    // req_obj_precision is declared as an @object var with a JSON-string value.
    // It is read raw from disk and parsed back into a JS object at read time.
    // Each numeric form is checked exactly so any precision drift between the
    // on-disk JSON and the runtime value would surface here.
    const v = bru.getRequestVar("req_obj_precision");
    expect(v.integer).to.equal(123);
    expect(v.negativeInteger).to.equal(-99);
    expect(v.zero).to.equal(0);
    expect(v.float).to.equal(2.718);
    expect(v.negativeFloat).to.equal(-1.618);
    expect(v.largeDouble).to.equal(12345.678901234567);
    expect(v.smallDouble).to.equal(9.876e-12);
    expect(v.booleanTrue).to.equal(true);
    expect(v.booleanFalse).to.equal(false);
  });

  test("collection environment vars carry their declared types", () => {
    expect(typeof bru.getEnvVar("env_str")).to.equal("string");
    expect(typeof bru.getEnvVar("env_num")).to.equal("number");
    expect(bru.getEnvVar("env_num")).to.equal(300);
    expect(typeof bru.getEnvVar("env_bool")).to.equal("boolean");
    expect(bru.getEnvVar("env_obj")).to.deep.equal({ scope: "env" });

    expect(typeof bru.getEnvVar("falsy_num")).to.equal("number");
    expect(bru.getEnvVar("falsy_num")).to.equal(0);
    expect(typeof bru.getEnvVar("falsy_bool")).to.equal("boolean");
    expect(bru.getEnvVar("falsy_bool")).to.equal(false);

    // A value with no declared dataType stays a string — a dataType is never
    // inferred from a parseable number/boolean/object value.
    expect(typeof bru.getEnvVar("env_untyped_num")).to.equal("string");
    expect(bru.getEnvVar("env_untyped_num")).to.equal("42");
    expect(typeof bru.getEnvVar("env_untyped_bool")).to.equal("string");
    expect(bru.getEnvVar("env_untyped_bool")).to.equal("true");
    expect(typeof bru.getEnvVar("env_untyped_obj")).to.equal("string");
    expect(bru.getEnvVar("env_untyped_obj")).to.equal('{"a":1}');
  });

  test("global environment vars carry their declared types", () => {
    expect(typeof bru.getGlobalEnvVar("glob_str")).to.equal("string");
    expect(typeof bru.getGlobalEnvVar("glob_num")).to.equal("number");
    expect(bru.getGlobalEnvVar("glob_num")).to.equal(400);
    expect(typeof bru.getGlobalEnvVar("glob_bool")).to.equal("boolean");
    expect(bru.getGlobalEnvVar("glob_obj")).to.deep.equal({ scope: "global" });

    // No declared dataType — parseable values stay strings, never inferred.
    expect(typeof bru.getGlobalEnvVar("glob_untyped_num")).to.equal("string");
    expect(bru.getGlobalEnvVar("glob_untyped_num")).to.equal("42");
    expect(typeof bru.getGlobalEnvVar("glob_untyped_bool")).to.equal("string");
    expect(bru.getGlobalEnvVar("glob_untyped_bool")).to.equal("true");
    expect(typeof bru.getGlobalEnvVar("glob_untyped_obj")).to.equal("string");
    expect(bru.getGlobalEnvVar("glob_untyped_obj")).to.equal('{"a":1}');
  });

  test("runtime vars set via bru.setVar preserve types", () => {
    expect(typeof bru.getVar("runtime_str")).to.equal("string");
    expect(typeof bru.getVar("runtime_num")).to.equal("number");
    expect(bru.getVar("runtime_num")).to.equal(999);
    expect(typeof bru.getVar("runtime_bool")).to.equal("boolean");
    expect(bru.getVar("runtime_obj")).to.deep.equal({ nested: "yes" });
  });

  test("setEnvVar infers dataType on the new env variable", () => {
    expect(typeof bru.getEnvVar("inferred_env_num")).to.equal("number");
    expect(bru.getEnvVar("inferred_env_num")).to.equal(700);
    expect(typeof bru.getEnvVar("inferred_env_bool")).to.equal("boolean");
    expect(bru.getEnvVar("inferred_env_bool")).to.equal(true);
    expect(bru.getEnvVar("inferred_env_obj")).to.deep.equal({ from: "script" });
  });

  test("setGlobalEnvVar infers dataType on the new global env variable", () => {
    expect(typeof bru.getGlobalEnvVar("inferred_glob_num")).to.equal("number");
    expect(bru.getGlobalEnvVar("inferred_glob_num")).to.equal(800);
    expect(typeof bru.getGlobalEnvVar("inferred_glob_bool")).to.equal("boolean");
    expect(bru.getGlobalEnvVar("inferred_glob_bool")).to.equal(false);
    expect(bru.getGlobalEnvVar("inferred_glob_obj")).to.deep.equal({ from: "script" });
  });

  test("bru.set* identifies type via the value's runtime type, not string content", () => {
    // Numeric / boolean / JSON-looking strings stay strings.
    expect(typeof bru.getEnvVar("strict_num_str")).to.equal("string");
    expect(bru.getEnvVar("strict_num_str")).to.equal("42");
    expect(typeof bru.getEnvVar("strict_bool_str")).to.equal("string");
    expect(bru.getEnvVar("strict_bool_str")).to.equal("true");
    expect(typeof bru.getEnvVar("strict_obj_str")).to.equal("string");
    expect(bru.getEnvVar("strict_obj_str")).to.equal('{"k":1}');
    // setGlobalEnvVar / setVar share the same contract.
    expect(typeof bru.getGlobalEnvVar("strict_glob_num_str")).to.equal("string");
    expect(typeof bru.getVar("strict_runtime_num_str")).to.equal("string");
  });

  test("secret env vars round-trip with their declared dataType", () => {
    // String secrets stay strings.
    expect(typeof bru.getEnvVar("env_secret_str")).to.equal("string");
    expect(bru.getEnvVar("env_secret_str")).to.equal("secret_env_string");
    expect(typeof bru.getGlobalEnvVar("glob_secret_str")).to.equal("string");
    expect(bru.getGlobalEnvVar("glob_secret_str")).to.equal("secret_global_string");
    // Typed secrets keep their JS type at runtime.
    expect(typeof bru.getEnvVar("env_secret_num")).to.equal("number");
    expect(bru.getEnvVar("env_secret_num")).to.equal(50);
    expect(typeof bru.getGlobalEnvVar("glob_secret_num")).to.equal("number");
    expect(bru.getGlobalEnvVar("glob_secret_num")).to.equal(60);
    expect(typeof bru.getEnvVar("env_secret_bool")).to.equal("boolean");
    expect(bru.getEnvVar("env_secret_bool")).to.equal(true);
    expect(typeof bru.getGlobalEnvVar("glob_secret_bool")).to.equal("boolean");
    expect(bru.getGlobalEnvVar("glob_secret_bool")).to.equal(false);
    expect(bru.getEnvVar("env_secret_obj")).to.deep.equal({ scope: "env_secret" });
    expect(bru.getGlobalEnvVar("glob_secret_obj")).to.deep.equal({ scope: "global_secret" });
  });

  test("typed vars in query params stringify on the wire", () => {
    // Query params are strings on the wire; objects get JSON.stringified.
    const query = res.getBody().query;
    expect(query.p_str).to.equal("request_string");
    expect(query.p_num).to.equal("42");
    expect(query.p_bool).to.equal("true");
    expect(query.p_obj).to.equal('{"key":"value"}');
  });

  test("typed vars in request headers stringify on the wire", () => {
    // The echo endpoint reflects request headers; Node lower-cases their names.
    const headers = res.getBody().headers;
    expect(headers["x-h-str"]).to.equal("request_string");
    expect(headers["x-h-num"]).to.equal("42");
    expect(headers["x-h-bool"]).to.equal("true");
    expect(headers["x-h-obj"]).to.equal('{"key":"value"}');
  });

  test("response body echoes typed values from every scope", () => {
    // The echo endpoint returns the raw request body; parse it back to JSON.
    const json = JSON.parse(res.getBody().body);
    expect(json.coll_num).to.equal(100);
    expect(json.coll_bool).to.equal(false);
    expect(json.coll_obj).to.deep.equal({ scope: "collection" });
    expect(json.fold_num).to.equal(200);
    expect(json.fold_bool).to.equal(true);
    expect(json.fold_obj).to.deep.equal({ scope: "folder" });
    expect(json.req_num).to.equal(42);
    expect(json.req_bool).to.equal(true);
    expect(json.req_obj).to.deep.equal({ key: "value" });
    // Precision must survive the file → substitution → wire → parse round-trip.
    expect(json.req_obj_precision.integer).to.equal(123);
    expect(json.req_obj_precision.negativeInteger).to.equal(-99);
    expect(json.req_obj_precision.zero).to.equal(0);
    expect(json.req_obj_precision.float).to.equal(2.718);
    expect(json.req_obj_precision.negativeFloat).to.equal(-1.618);
    expect(json.req_obj_precision.largeDouble).to.equal(12345.678901234567);
    expect(json.req_obj_precision.smallDouble).to.equal(9.876e-12);
    expect(json.req_obj_precision.booleanTrue).to.equal(true);
    expect(json.req_obj_precision.booleanFalse).to.equal(false);
    expect(json.req_obj_empty).to.deep.equal({});
    expect(json.req_arr).to.deep.equal([1, 2, "three", true]);
    expect(json.mismatched_num).to.equal("not-a-number");
    expect(json.env_num).to.equal(300);
    expect(json.env_bool).to.equal(true);
    expect(json.env_obj).to.deep.equal({ scope: "env" });
    expect(json.falsy_num).to.equal(0);
    expect(json.falsy_bool).to.equal(false);
    expect(json.glob_num).to.equal(400);
    expect(json.glob_bool).to.equal(false);
    expect(json.glob_obj).to.deep.equal({ scope: "global" });
    expect(json.runtime_num).to.equal(999);
    expect(json.runtime_bool).to.equal(true);
    expect(json.runtime_obj).to.deep.equal({ nested: "yes" });
    expect(json.inferred_env_num).to.equal(700);
    expect(json.inferred_env_bool).to.equal(true);
    expect(json.inferred_env_obj).to.deep.equal({ from: "script" });
    expect(json.inferred_glob_num).to.equal(800);
    expect(json.inferred_glob_bool).to.equal(false);
    expect(json.inferred_glob_obj).to.deep.equal({ from: "script" });
    expect(json.env_secret_str).to.equal("secret_env_string");
    expect(json.glob_secret_str).to.equal("secret_global_string");
    expect(json.env_secret_num).to.equal(50);
    expect(json.glob_secret_num).to.equal(60);
    expect(json.env_secret_bool).to.equal(true);
    expect(json.glob_secret_bool).to.equal(false);
    expect(json.env_secret_obj).to.deep.equal({ scope: "env_secret" });
    expect(json.glob_secret_obj).to.deep.equal({ scope: "global_secret" });
  });
}
