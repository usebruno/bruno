example {
  name: created-201

  request: {
    url: https://api.example.com/users
    method: post
    mode: json
    body:json: {
      {
        "name": "New User",
        "email": "new@example.com"
      }
    }
  }

  response: {
    status: {
      code: 201
      text: Created
    }

    body: {
      type: json
      content: '''
        {
          "id": 2,
          "name": "New User",
          "email": "new@example.com"
        }
      '''
    }
  }
}
