meta {
  name: col-description
  type: collection
  version: 1.0.0
}

headers {
  X-Version: 2.0 @description('''Single-line header desc''')
  X-Multi: value @description('''
    Header line one
    Header line two
  ''')
  X-Plain: plain-value
}

vars:pre-request {
  baseUrl: https://example.com @description('''Single-line var desc''')
  apiKey: abc123 @description('''
    Var line one
    Var line two
  ''')
  plain: no-desc
}
