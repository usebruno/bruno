meta {
  name: cross-origin-redirect-auth-strip
  type: http
  seq: 4
}

get {
  url: http://127.0.0.1:8081/api/redirect/cross-origin
  body: none
  auth: none
}

headers {
  Authorization: Bearer token-test
  Proxy-Authorization: Bearer proxy-test
}

settings {
  followRedirects: true
  forwardAuthorizationOnRedirect: false
  maxRedirects: 5
  timeout: 0
}
