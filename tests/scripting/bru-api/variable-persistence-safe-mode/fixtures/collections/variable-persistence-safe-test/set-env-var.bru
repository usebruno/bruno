meta {
  name: set-env-var
  type: http
  seq: 1
}

get {
  url: {{host}}/ping
  body: none
  auth: none
}

script:post-response {
  bru.setEnvVar("persistedToken", "test-value-123");
}

tests {
  test("should set env var", function() {
    const val = bru.getEnvVar("persistedToken");
    expect(val).to.equal("test-value-123");
  });
}
