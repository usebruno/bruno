meta {
  name: forbidden
  type: http
  seq: 3
}

get {
  url: http://httpfaker.org/api/echo
  body: none
  auth: none
}

tests {
  test('ancestor node_modules is NOT resolvable via require', function() {
    let threw = false;
    try {
      require('forbidden-lib');
    } catch (e) {
      threw = true;
    }
    expect(threw).to.equal(true);
  });
}
