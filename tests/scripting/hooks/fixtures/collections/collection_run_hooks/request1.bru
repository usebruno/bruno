meta {
  name: Request 1
  type: http
  seq: 1
}

post {
  url: {{host}}/api/echo/json
  body: none
  auth: none
}

tests {
  test("collectionRunStart hook should have executed", function() {
    const started = bru.getEnvVar('collection_started');
    expect(started).to.equal('true');
  });
  
  test("collectionRunStart should have set start_time", function() {
    const startTime = bru.getEnvVar('start_time');
    expect(startTime).to.be.a('string');
    expect(parseInt(startTime)).to.be.a('number');
    expect(parseInt(startTime)).to.be.greaterThan(0);
  });
  
  test("request1 should set end time", function() {
    const endTime = Date.now().toString();
    bru.setEnvVar('request1_end_time', endTime);
    expect(parseInt(endTime)).to.be.a('number');
  });
  
  test("start_time should be before request1 end time", function() {
    const startTime = parseInt(bru.getEnvVar('start_time'));
    const request1EndTime = parseInt(bru.getEnvVar('request1_end_time'));
    expect(startTime).to.be.lessThan(request1EndTime);
  });
  
  test("request should succeed", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
