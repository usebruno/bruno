meta {
  name: local-env-var-override
  type: http
}

http {
  method: POST
  url: https://echo.usebruno.com
  body: json
  auth: none
}

body:json {
  {
    "wibble": "{{wibble}}"
  }
}

tests {
  test("local env var wibble is overridden via --env-var", function() {
    expect(bru.getEnvVar("wibble")).to.equal("wobblewobble");
  });
}
