{
  "version": "1",
  "name": "client-certs-disabled",
  "type": "collection",
  "ignore": ["node_modules", ".git"],
  "clientCertificates": {
    "enabled": true,
    "certs": [
      {
        "domain": "localhost",
        "type": "cert",
        "certFilePath": "../../server/certs/client-cert.pem",
        "keyFilePath": "../../server/certs/client-key.pem",
        "passphrase": "",
        "disabled": true
      }
    ]
  }
}
