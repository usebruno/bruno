{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["es2021"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "rootDir": "internal",
    "outDir": "dist",
    "types": ["node"],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["internal/**/*.ts"],
  "exclude": ["node_modules", "dist", "internal/templates"]
}
