meta {
  name: ping
  type: http
  seq: 1
}

get {
  url: {{host}}/ping?singer=micheal jackson
  body: none
  auth: none
}

params:query {
  singer: micheal jackson
}

script:pre-request {
  bru.runner.stopExecution();
}

settings {
  encodeUrl: false
  timeout: inherit
  followRedirects: true
  maxRedirects: 5
}
