meta {
  name: getUrl
  type: http
  seq: 1
}

get {
  url: {{host}}/ping
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body: eq pong
}

tests {
  test("req.getUrl()", function() {
    const host = bru.getEnvVar("host");
    const url = req.getUrl();
    expect(url).to.equal(host + "/ping");
  });
}
