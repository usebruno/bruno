meta {
  name: getHeader
  type: http
  seq: 5
}

get {
  url: {{host}}/ping
  body: none
  auth: none
}

headers {
  bruno: is-awesome
  Content-Type: application/json
}


assert {
  res.status: eq 200
  res.body: eq pong
}

tests {
  test("req.getHeader(name)", function() {
    const h = req.getHeader('bruno');
    expect(h).to.equal("is-awesome");
  });

  test("case sensitive check", function() {
    const h=req.getHeader('Content-Type');
    expect(h).to.equal("application/json")
  } )
}