meta {
  name: setUrl
  type: http
  seq: 2
}

get {
  url: {{host}}/ping/invalid
  body: none
  auth: none
}


assert {
  res.status: eq 200
  res.body: eq pong
}

script:pre-request {
  const host = bru.getEnvVar("host");
  req.setUrl(host + "/ping");
}

tests {
  test("req.setUrl()", function() {
    const host = bru.getEnvVar("host");
    const url = req.getUrl();
    expect(url).to.equal(host + "/ping");
  });
}