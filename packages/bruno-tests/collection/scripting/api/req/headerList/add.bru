meta {
  name: add
  type: http
  seq: 5
}

get {
  url: {{host}}/ping
  body: none
  auth: none
}

headers {
  bruno: is-awesome
}

assert {
  res.status: eq 200
  res.body: eq pong
}

script:pre-request {
  req.headerList.add({ key: 'x-added', value: 'via-add' });
  req.headerList.upsert({ key: 'x-upserted', value: 'via-upsert' });
  req.headerList.append({ key: 'x-appended', value: 'via-append' });
  req.headerList.prepend({ key: 'x-prepended', value: 'via-prepend' });
  req.headerList.insert({ key: 'x-inserted', value: 'via-insert' });
  req.headerList.insertAfter({ key: 'x-inserted-after', value: 'via-insertAfter' });
  req.headerList.upsert({ key: 'bruno', value: 'is-the-best' });
}

tests {
  test("req.headerList.add(item)", function() {
    expect(req.getHeader('x-added')).to.equal('via-add');
  });

  test("req.headerList.upsert(item) - new header", function() {
    expect(req.getHeader('x-upserted')).to.equal('via-upsert');
  });

  test("req.headerList.upsert(item) - overwrite existing", function() {
    expect(req.getHeader('bruno')).to.equal('is-the-best');
  });

  test("req.headerList.append(item)", function() {
    expect(req.getHeader('x-appended')).to.equal('via-append');
  });

  test("req.headerList.prepend(item)", function() {
    expect(req.getHeader('x-prepended')).to.equal('via-prepend');
  });

  test("req.headerList.insert(item)", function() {
    expect(req.getHeader('x-inserted')).to.equal('via-insert');
  });

  test("req.headerList.insertAfter(item)", function() {
    expect(req.getHeader('x-inserted-after')).to.equal('via-insertAfter');
  });
}
