meta {
  name: populate
  type: http
  seq: 8
}

get {
  url: {{host}}/ping
  body: none
  auth: none
}

headers {
  bruno: is-awesome
  della: is-beautiful
}

assert {
  res.status: eq 200
  res.body: eq pong
}

script:pre-request {
  req.headerList.populate([
    { key: 'x-new-one', value: 'one' },
    { key: 'x-new-two', value: 'two' }
  ]);
}

tests {
  test("req.headerList.populate(items) - replaces all headers", function() {
    expect(req.getHeader('bruno')).to.be.undefined;
    expect(req.getHeader('della')).to.be.undefined;
    expect(req.getHeader('x-new-one')).to.equal('one');
    expect(req.getHeader('x-new-two')).to.equal('two');
    expect(req.headerList.count()).to.equal(2);
  });
}
