meta {
  name: readMethods
  type: http
  seq: 3
}

get {
  url: {{host}}/ping
  body: none
  auth: inherit
}

script:pre-request {
  bru.variables.set("x", "10");
  bru.variables.set("y", "20");
}

tests {
  test("one() should return full item object", function() {
    const item = bru.variables.one("x");
    expect(item).to.have.property("key", "x");
    expect(item).to.have.property("value", "10");
  });

  test("one() should return undefined for missing key", function() {
    expect(bru.variables.one("missing")).to.be.undefined;
  });

  test("all() should return array of { key, value } items", function() {
    const items = bru.variables.all();
    expect(items).to.be.an("array");
    expect(items.length).to.be.at.least(2);
    expect(items[0]).to.have.property("key");
    expect(items[0]).to.have.property("value");
  });

  test("count() should return the number of variables", function() {
    expect(bru.variables.count()).to.be.at.least(2);
  });

  test("idx() should return item at positional index", function() {
    const item = bru.variables.idx(0);
    expect(item).to.have.property("key");
    expect(item).to.have.property("value");
  });

  test("toObject() should return plain { key: value } map", function() {
    const obj = bru.variables.toObject();
    expect(obj).to.be.an("object");
    expect(obj).to.have.property("x", "10");
    expect(obj).to.have.property("y", "20");
  });

  test("toString() should return key=value pairs", function() {
    const str = bru.variables.toString();
    expect(str).to.be.a("string");
    expect(str).to.contain("x=10");
  });

  test("toJSON() should return same as all()", function() {
    const json = bru.variables.toJSON();
    expect(json).to.be.an("array");
    expect(json.length).to.be.at.least(2);
  });

  bru.variables.clear();
}
