meta {
  name: iteration
  type: http
  seq: 4
}

get {
  url: {{host}}/ping
  body: none
  auth: inherit
}

script:pre-request {
  bru.globals.set("gA", "1");
  bru.globals.set("gB", "2");
  bru.globals.set("gC", "3");
}

tests {
  test("each() should iterate over all variables", function() {
    const keys = [];
    bru.globals.each(function(item) {
      keys.push(item.key);
    });
    expect(keys).to.include("gA");
    expect(keys).to.include("gB");
    expect(keys).to.include("gC");
  });

  test("find() should return matching item", function() {
    const item = bru.globals.find(function(i) { return i.key === "gB"; });
    expect(item).to.have.property("value", "2");
  });

  test("filter() should return matching items", function() {
    const result = bru.globals.filter(function(i) { return i.key.startsWith("g"); });
    expect(result).to.be.an("array");
    expect(result.length).to.be.at.least(3);
  });

  test("map() should transform items", function() {
    const keys = bru.globals.map(function(i) { return i.key; });
    expect(keys).to.include("gA");
    expect(keys).to.include("gB");
  });

  test("reduce() should accumulate values", function() {
    const items = bru.globals.filter(function(i) { return ["gA", "gB", "gC"].indexOf(i.key) !== -1; });
    const sum = items.reduce(function(acc, i) { return acc + Number(i.value); }, 0);
    expect(sum).to.equal(6);
  });
}
