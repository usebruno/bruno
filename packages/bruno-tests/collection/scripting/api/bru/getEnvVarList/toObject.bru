meta {
  name: toObject
  type: http
  seq: 5
}

get {
  url: {{host}}/ping
  body: none
  auth: none
}

tests {
  test("should return a plain object with env vars", function() {
    const envVarList = bru.getEnvVarList();
    const obj = envVarList.toObject();
    expect(obj.host).to.be.a("string");
  });

  test("should not include __name__ in toObject()", function() {
    const envVarList = bru.getEnvVarList();
    const obj = envVarList.toObject();
    expect(obj.__name__).to.be.undefined;
  });
}
