meta {
  name: delete
  type: http
  seq: 3
}

get {
  url: {{host}}/ping
  body: none
  auth: none
}

script:pre-request {
  const envVarList = bru.getEnvVarList();
  envVarList.set("testEnvVarListDelete", "to-be-deleted");
}

tests {
  test("should delete an env var", function() {
    const envVarList = bru.getEnvVarList();
    expect(envVarList.has("testEnvVarListDelete")).to.equal(true);
    envVarList.delete("testEnvVarListDelete");
    expect(envVarList.has("testEnvVarListDelete")).to.equal(false);
  });
}
