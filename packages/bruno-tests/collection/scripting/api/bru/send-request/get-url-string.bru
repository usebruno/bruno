meta {
  name: get-url-string
  type: http
  seq: 1
}

post {
  url: {{echo-host}}
  body: none
  auth: inherit
}

tests {
  await test("send request with a get url string", async () => {
    const host = bru.getEnvVar("host");
    const res = await bru.sendRequest(host + "/ping");
    expect(res.data).to.eql('pong');
  });
}
