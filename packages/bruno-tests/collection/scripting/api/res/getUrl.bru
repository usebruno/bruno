meta {
  name: getUrl
  type: http
  seq: 1
}

get {
  url: {{host}}/ping
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body: eq pong
}

tests {
  test("res.url", function() {
    expect(res.url).to.be.a("string");
    expect(res.url).to.match(/\/ping$/);
  });

  test("res.getUrl()", function() {
    const url = res.getUrl();
    expect(url).to.be.a("string");
    expect(url).to.equal(res.url);
  });
}
