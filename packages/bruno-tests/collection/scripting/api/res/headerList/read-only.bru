meta {
  name: read-only
  type: http
  seq: 5
}

post {
  url: {{host}}/api/echo/json
  body: json
  auth: none
}

body:json {
  {
    "hello": "bruno"
  }
}

assert {
  res.status: eq 200
}

tests {
  test("res.headerList.add() throws read-only error", function() {
    expect(() => res.headerList.add({ key: 'x-test', value: 'test' })).to.throw('read-only');
  });

  test("res.headerList.upsert() throws read-only error", function() {
    expect(() => res.headerList.upsert({ key: 'x-test', value: 'test' })).to.throw('read-only');
  });

  test("res.headerList.remove() throws read-only error", function() {
    expect(() => res.headerList.remove('x-powered-by')).to.throw('read-only');
  });

  test("res.headerList.clear() throws read-only error", function() {
    expect(() => res.headerList.clear()).to.throw('read-only');
  });

  test("res.headerList.populate() throws read-only error", function() {
    expect(() => res.headerList.populate([])).to.throw('read-only');
  });
}
