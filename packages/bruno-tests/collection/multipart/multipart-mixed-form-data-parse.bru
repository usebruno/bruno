meta {
  name: multipart-mixed-form-data-parse
  type: http
  seq: 1
}

post {
  url: {{echo-host}}
  body: multipartForm
  auth: none
}

headers {
  Content-Type: multipart/mixed
}

body:multipart-form {
  sample: sample
}

assert {
  res.body: matches ^[-]+[a-z0-9]+
  res.body: matches Content-Type:\s*multipart\/mixed;\s*boundary=
}
