meta {
  name: developer-mode-after-response
  type: http
  seq: 1
}

get {
  url: {{host}}/ping
  body: none
  auth: none
}

script:hooks {
  bru.hooks.onAfterResponse(({ req, res }) => {
    console.log('[afterResponse] Developer mode - afterResponse hook');
    
    // Test: Can access req and res objects in developer mode
    const reqUrl = req.getUrl();
    const status = res.getStatus();
    const body = res.getBody();
    
    // Test: Can use bru APIs in developer mode
    bru.setVar('developer-mode-afterResponse-executed', 'true');
    bru.setVar('developer-mode-status', status.toString());
    bru.setVar('developer-mode-body', body);
    bru.setVar('developer-mode-req-url', reqUrl);
    
    console.log('[afterResponse] Developer mode hook completed');
  });
}

tests {
  test("developer mode afterResponse hook should have executed", function() {
    const executed = bru.getVar('developer-mode-afterResponse-executed');
    expect(executed).to.equal('true');
  });
  
  test("should have access to response in developer mode", function() {
    const status = bru.getVar('developer-mode-status');
    expect(status).to.equal('200');
  });
  
  test("should have access to response body in developer mode", function() {
    const body = bru.getVar('developer-mode-body');
    expect(body).to.equal('pong');
  });
}

